---
interface Props {
  title?: string;
}
const { title = "Summer Game Lawn Code Bike Router" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-slate-50 text-slate-900 min-h-screen antialiased">
    <slot />
  </body>
</html>
